{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/locomproAqui/browser",
  "build": {
    "env": {
      "NODE_OPTIONS": "--openssl-legacy-provider --max-old-space-size=6144"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff|woff2|ttf|eot|otf|png|jpg|jpeg|gif|svg|webp|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
