{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/locomproAqui/browser",
  "build": {
    "env": {
      "NODE_OPTIONS": "--openssl-legacy-provider --max-old-space-size=6144"
    }
  },
  "rewrites": [
    { "source": "/mfe-ping", "destination": "https://lokomproaqui-next.vercel.app/mfe-ping" },
    { "source": "/tutoriales", "destination": "https://lokomproaqui-next.vercel.app/tutoriales" },
    { "source": "/infoSupplier", "destination": "https://lokomproaqui-next.vercel.app/infoSupplier" },
    { "source": "/portal", "destination": "https://lokomproaqui-next.vercel.app/portal" },
    { "source": "/testimonio", "destination": "https://lokomproaqui-next.vercel.app/testimonio" },
    { "source": "/info", "destination": "https://lokomproaqui-next.vercel.app/info" },
    { "source": "/login", "destination": "https://lokomproaqui-next.vercel.app/login" },
    { "source": "/singUp", "destination": "https://lokomproaqui-next.vercel.app/singUp" },
    { "source": "/singUp/:path*", "destination": "https://lokomproaqui-next.vercel.app/singUp/:path*" },
    { "source": "/mvid8x2qz1", "destination": "https://lokomproaqui-next.vercel.app/mvid8x2qz1" },
    { "source": "/mvid8x2qz1/panel", "destination": "https://lokomproaqui-next.vercel.app/mvid8x2qz1/panel" },
    { "source": "/registro", "destination": "https://lokomproaqui-next.vercel.app/registro" },
    { "source": "/_next/:path*", "destination": "https://lokomproaqui-next.vercel.app/_next/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, s-maxage=0" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff|woff2|ttf|eot|otf|png|jpg|jpeg|gif|svg|webp|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
